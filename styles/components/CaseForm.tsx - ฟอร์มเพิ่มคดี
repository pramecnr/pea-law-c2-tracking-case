import React, { useState } from 'react';
import { collection, addDoc, Timestamp } from 'firebase/firestore';
import { ref, uploadBytes, getDownloadURL } from 'firebase/storage';
import { db, storage } from '../firebase';

interface CaseFormProps {
  onCaseAdded: () => void;
}

export default function CaseForm({ onCaseAdded }: CaseFormProps) {
  const [formData, setFormData] = useState({
    caseNumberBlack: '',
    caseNumberRed: '',
    plaintiffName: '',
    defendantName: '',
    filingDate: '',
    caseStatus: 'รอพิจารณา',
    notes: '',
  });

  const [files, setFiles] = useState<File[]>([]);
  const [loading, setLoading] = useState(false);
  const [message, setMessage] = useState<{ type: 'success' | 'error'; text: string } | null>(null);

  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files) {
      setFiles(Array.from(e.target.files));
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    setMessage(null);

    try {
      const fileUrls: string[] = [];

      // Upload files
      for (const file of files) {
        const fileRef = ref(storage, `cases/${Date.now()}_${file.name}`);
        await uploadBytes(fileRef, file);
        const url = await getDownloadURL(fileRef);
        fileUrls.push(url);
      }

      // Save case data
      await addDoc(collection(db, 'cases'), {
        ...formData,
        fileUrls,
        createdAt: Timestamp.now(),
      });

      setMessage({ type: 'success', text: 'บันทึกข้อมูลคดีสำเร็จ!' });
      setFormData({
        caseNumberBlack: '',
        caseNumberRed: '',
        plaintiffName: '',
        defendantName: '',
        filingDate: '',
        caseStatus: 'รอพิจารณา',
        notes: '',
      });
      setFiles([]);
      onCaseAdded();
    } catch (error) {
      setMessage({ type: 'error', text: 'เกิดข้อผิดพลาด: ' + (error as Error).message });
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="form-container">
      <h2 style={{ color: '#6a1b9a', marginBottom: '20px' }}>เพิ่มข้อมูลคดีใหม่</h2>
      
      {message && (
        <div className={message.type === 'success' ? 'success' : 'error'}>
          {message.text}
        </div>
      )}

      <form onSubmit={handleSubmit}>
        <div className="form-group">
          <label>เลขคดีดำ (Black Number)</label>
          <input
            type="text"
            name="caseNumberBlack"
            value={formData.caseNumberBlack}
            onChange={handleInputChange}
            placeholder="เช่น ดด.1234/2566"
          />
        </div>

        <div className="form-group">
          <label>เลขคดีแดง (Red Number)</label>
          <input
            type="text"
            name="caseNumberRed"
            value={formData.caseNumberRed}
            onChange={handleInputChange}
            placeholder="เช่น ดร.5678/2566"
          />
        </div>

        <div className="form-group">
          <label>ชื่อโจทก์ (Plaintiff)</label>
          <input
            type="text"
            name="plaintiffName"
            value={formData.plaintiffName}
            onChange={handleInputChange}
            required
          />
        </div>

        <div className="form-group">
          <label>ชื่อจำเลย (Defendant)</label>
          <input
            type="text"
            name="defendantName"
            value={formData.defendantName}
            onChange={handleInputChange}
            required
          />
        </div>

        <div className="form-group">
          <label>วันที่ยื่นคดี</label>
          <input
            type="date"
            name="filingDate"
            value={formData.filingDate}
            onChange={handleInputChange}
            required
          />
        </div>

        <div className="form-group">
          <label>สถานะคดี</label>
          <select name="caseStatus" value={formData.caseStatus} onChange={handleInputChange}>
            <option>รอพิจารณา</option>
            <option>พิจารณาอยู่</option>
            <option>รอคำพิพากษา</option>
            <option>พิพากษาแล้ว</option>
            <option>อุทธรณ์</option>
            <option>เสร็จสิ้น</option>
          </select>
        </div>

        <div className="form-group">
          <label>หมายเหตุ</label>
          <textarea
            name="notes"
            value={formData.notes}
            onChange={handleInputChange}
            placeholder="เพิ่มหมายเหตุเพิ่มเติม..."
          />
        </div>

        <div className="form-group">
          <label>อัพโหลดไฟล์เอกสาร</label>
          <input
            type="file"
            multiple
            onChange={handleFileChange}
          />
          {files.length > 0 && (
            <p style={{ color: '#6a1b9a', marginTop: '10px' }}>
              เลือกไฟล์แล้ว {files.length} ไฟล์
            </p>
          )}
        </div>

        <button type="submit" disabled={loading}>
          {loading ? 'กำลังบันทึก...' : 'บันทึกข้อมูลคดี'}
        </button>
      </form>
    </div>
  );
}
